# Copy to .env.local and fill in your OpenRouter key.
# Get a free key at https://openrouter.ai/keys

# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
LLM_FALLBACK_MODELS=tencent/hy3:free,nvidia/nemotron-3-super-120b-a12b:free,qwen/qwen3-next-80b-a3b-instruct:free

# --- Processing ---
BATCH_SIZE=25
MAX_RETRIES=2
MAX_UPLOAD_BYTES=5242880
